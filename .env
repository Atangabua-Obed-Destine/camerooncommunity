APP_NAME="Cameroon Community"
APP_ENV=production
APP_KEY=base64:KR//cBkpqtKHnjgCWICK17x1Qb7FkIf371Br/YF+Lh8=
APP_DEBUG=true
APP_URL=http://localhost/camerooncommunity/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (MySQL via XAMPP) ───
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cameroon_community
DB_USERNAME=root
DB_PASSWORD=

# ─── Session ───
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting (Laravel Reverb) ───
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=cameroon-community
REVERB_APP_KEY=cameroon-community-key
REVERB_APP_SECRET=cameroon-community-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Metered TURN Server ───
METERED_DOMAIN=camerooncommunity.metered.live
METERED_SECRET_KEY=t3q-cBxgkrnja3ZqrVyt4YA1thaeVQTwhW7eOJOtYbr-2Qu2

# ─── Cache & Queue (Redis when available, database for dev) ───
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ───
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@camerooncommunity.net"
MAIL_FROM_NAME="Cameroon Community"

# ─── Telescope ───
TELESCOPE_ENABLED=false

