<div x-data="callEngine(@js(auth()->id()), @js(app('currentTenant')?->id))"
     @call-started.window="onCallStarted($event.detail)"
     @call-answered.window="onCallAnswered($event.detail)"
     @call-ended.window="onCallEnded()"
     @call-error.window="showError($event.detail.message)"
     @initiate-call.window="$wire.initiateCall($event.detail.roomId, $event.detail.type)"
     class="relative z-[200]">

    {{-- ════════════════════════════════════════════════════════
         INCOMING CALL OVERLAY
    ════════════════════════════════════════════════════════ --}}
    <template x-if="incomingCall">
        <div class="fixed inset-0 z-[201] bg-black/70 backdrop-blur-sm flex items-center justify-center"
             x-transition>
            <div class="bg-white rounded-3xl w-80 overflow-hidden shadow-2xl animate-fade-in">
                {{-- Gradient header --}}
                <div class="bg-gradient-to-br from-cm-green via-cm-green-dark to-slate-900 px-6 py-8 text-center relative overflow-hidden">
                    {{-- Animated rings --}}
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-32 h-32 rounded-full border-2 border-white/10 animate-ping" style="animation-duration:2s"></div>
                    </div>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-24 h-24 rounded-full border-2 border-white/10 animate-ping" style="animation-duration:2s;animation-delay:0.5s"></div>
                    </div>

                    {{-- Caller avatar --}}
                    <div class="relative w-20 h-20 mx-auto rounded-full bg-cm-yellow flex items-center justify-center text-2xl font-extrabold text-cm-green shadow-lg mb-4">
                        <span x-text="incomingCall?.callerName?.charAt(0)?.toUpperCase() || '?'"></span>
                    </div>
                    <h3 class="text-white font-bold text-lg" x-text="incomingCall?.callerName || 'Unknown'"></h3>
                    <p class="text-white/60 text-sm mt-1" x-text="incomingCall?.roomName || ''"></p>
                    <div class="flex items-center justify-center gap-2 mt-3">
                        <span class="inline-flex items-center gap-1.5 text-cm-yellow text-xs font-semibold">
                            <template x-if="incomingCall?.callType === 'video'">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25z"/></svg>
                            </template>
                            <template x-if="incomingCall?.callType === 'voice'">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z"/></svg>
                            </template>
                            <span x-text="incomingCall?.callType === 'video' ? 'Video Call' : 'Voice Call'"></span>
                        </span>
                    </div>
                </div>

                {{-- Action buttons --}}
                <div class="flex justify-center gap-6 py-6 bg-slate-50">
                    {{-- Decline --}}
                    <button @click="decline()"
                            class="group flex flex-col items-center gap-1.5">
                        <div class="w-14 h-14 rounded-full bg-red-500 hover:bg-red-600 flex items-center justify-center shadow-lg transition-all group-hover:scale-110">
                            <svg class="w-7 h-7 text-white rotate-[135deg]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z"/></svg>
                        </div>
                        <span class="text-[11px] text-slate-500 font-medium" x-text="$store.lang.t('Decline', 'Refuser')"></span>
                    </button>

                    {{-- Accept --}}
                    <button @click="accept()"
                            class="group flex flex-col items-center gap-1.5">
                        <div class="w-14 h-14 rounded-full bg-green-500 hover:bg-green-600 flex items-center justify-center shadow-lg transition-all group-hover:scale-110 animate-pulse">
                            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z"/></svg>
                        </div>
                        <span class="text-[11px] text-slate-500 font-medium" x-text="$store.lang.t('Accept', 'Accepter')"></span>
                    </button>
                </div>
            </div>
        </div>
    </template>

    {{-- ════════════════════════════════════════════════════════
         OUTGOING CALL (RINGING) OVERLAY
    ════════════════════════════════════════════════════════ --}}
    <template x-if="callState === 'outgoing'">
        <div class="fixed inset-0 z-[201] bg-gradient-to-b from-cm-green via-cm-green-dark to-slate-900 flex flex-col items-center justify-center"
             x-transition>
            <div class="text-center">
                {{-- Ringing animation --}}
                <div class="relative w-28 h-28 mx-auto mb-6">
                    <div class="absolute inset-0 rounded-full bg-white/5 animate-ping" style="animation-duration:1.5s"></div>
                    <div class="absolute inset-2 rounded-full bg-white/5 animate-ping" style="animation-duration:1.5s;animation-delay:0.3s"></div>
                    <div class="relative w-28 h-28 rounded-full bg-cm-yellow flex items-center justify-center text-3xl font-extrabold text-cm-green shadow-xl">
                        <span x-text="callRoomName?.charAt(0)?.toUpperCase() || '?'"></span>
                    </div>
                </div>

                <h2 class="text-white text-xl font-bold" x-text="callRoomName"></h2>
                <p class="text-white/50 text-sm mt-2" x-text="callType === 'video' ? 'Video calling...' : 'Calling...'"></p>

                {{-- Timer --}}
                <p class="text-white/40 text-xs mt-3 font-mono" x-text="ringTimer"></p>
            </div>

            {{-- Cancel button --}}
            <div class="mt-16">
                <button @click="hangUp()"
                        class="w-16 h-16 rounded-full bg-red-500 hover:bg-red-600 flex items-center justify-center shadow-lg transition-all hover:scale-110">
                    <svg class="w-8 h-8 text-white rotate-[135deg]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z"/></svg>
                </button>
            </div>
        </div>
    </template>

    {{-- ════════════════════════════════════════════════════════
         ACTIVE CALL SCREEN
    ════════════════════════════════════════════════════════ --}}
    <template x-if="callState === 'active'">
        <div class="fixed inset-0 z-[201] bg-slate-900 flex flex-col" x-transition>

            {{-- Video area --}}
            <div class="flex-1 relative overflow-hidden" :class="callType === 'voice' ? 'bg-gradient-to-b from-cm-green-dark to-slate-900' : 'bg-black'">

                {{-- Remote video(s) / Voice UI --}}
                <template x-if="callType === 'video'">
                    <div class="h-full w-full grid" :class="remoteStreams.length <= 1 ? 'grid-cols-1' : remoteStreams.length <= 4 ? 'grid-cols-2' : 'grid-cols-3'" id="remote-videos">
                        <template x-for="stream in remoteStreams" :key="stream.peerId">
                            <div class="relative bg-slate-800 flex items-center justify-center">
                                <video :id="'remote-video-' + stream.peerId" autoplay playsinline
                                       class="w-full h-full object-cover" x-ref="remoteVid"></video>
                                <div class="absolute bottom-2 left-2 bg-black/50 text-white text-xs px-2 py-1 rounded-lg"
                                     x-text="stream.name"></div>
                            </div>
                        </template>
                        {{-- Empty state if no remote streams yet --}}
                        <template x-if="remoteStreams.length === 0">
                            <div class="h-full flex items-center justify-center">
                                <div class="text-center">
                                    <div class="w-24 h-24 mx-auto rounded-full bg-cm-yellow/20 flex items-center justify-center text-3xl font-bold text-cm-yellow mb-4">
                                        <span x-text="callRoomName?.charAt(0)?.toUpperCase() || '?'"></span>
                                    </div>
                                    <p class="text-white/60 text-sm" x-text="$store.lang.t('Connecting...', 'Connexion...')"></p>
                                </div>
                            </div>
                        </template>
                    </div>
                </template>

                {{-- Voice call UI: participants in a circle --}}
                <template x-if="callType === 'voice'">
                    <div class="h-full flex flex-col items-center justify-center gap-6">
                        <div class="flex flex-wrap items-center justify-center gap-4">
                            <template x-for="p in callParticipants" :key="p.user_id">
                                <div class="flex flex-col items-center gap-2">
                                    <div class="w-20 h-20 rounded-full flex items-center justify-center text-2xl font-extrabold shadow-xl transition-all"
                                         :class="p.status === 'joined' ? 'bg-cm-yellow text-cm-green scale-100' : 'bg-slate-700 text-slate-400 scale-90 opacity-60'">
                                        <span x-text="p.initial"></span>
                                    </div>
                                    <span class="text-white/70 text-xs font-medium" x-text="p.name"></span>
                                    <template x-if="p.is_muted">
                                        <span class="text-red-400 text-[10px]">muted</span>
                                    </template>
                                </div>
                            </template>
                        </div>
                        <p class="text-white/50 text-sm font-mono mt-4" x-text="callDuration"></p>
                    </div>
                </template>

                {{-- Local video (picture-in-picture) --}}
                <template x-if="callType === 'video'">
                    <div class="absolute top-4 right-4 w-32 h-44 sm:w-40 sm:h-56 rounded-2xl overflow-hidden shadow-xl border-2 border-slate-700 bg-slate-800 cursor-move"
                         x-show="!isVideoOff" x-transition>
                        <video id="local-video" autoplay playsinline muted class="w-full h-full object-cover"></video>
                    </div>
                </template>
            </div>

            {{-- Call info bar --}}
            <div class="bg-slate-800/80 backdrop-blur px-4 py-2 flex items-center justify-between">
                <div>
                    <p class="text-white text-sm font-semibold" x-text="callRoomName"></p>
                    <p class="text-white/40 text-xs font-mono" x-text="callDuration"></p>
                </div>
                <div class="text-white/40 text-xs">
                    <span x-text="callParticipants.filter(p => p.status === 'joined').length"></span>
                    <span x-text="$store.lang.t('participants', 'participants')"></span>
                </div>
            </div>

            {{-- Controls bar --}}
            <div class="bg-slate-900 px-4 py-5 flex items-center justify-center gap-4">
                {{-- Mute --}}
                <button @click="toggleMute()"
                        class="w-12 h-12 rounded-full flex items-center justify-center transition-all"
                        :class="isMuted ? 'bg-white text-slate-900' : 'bg-slate-700 text-white hover:bg-slate-600'">
                    <template x-if="!isMuted">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3z"/></svg>
                    </template>
                    <template x-if="isMuted">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3z"/><line x1="3" y1="3" x2="21" y2="21" stroke="currentColor" stroke-width="2"/></svg>
                    </template>
                </button>

                {{-- Camera toggle (video calls only) --}}
                <template x-if="callType === 'video'">
                    <button @click="toggleVideo()"
                            class="w-12 h-12 rounded-full flex items-center justify-center transition-all"
                            :class="isVideoOff ? 'bg-white text-slate-900' : 'bg-slate-700 text-white hover:bg-slate-600'">
                        <template x-if="!isVideoOff">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25z"/></svg>
                        </template>
                        <template x-if="isVideoOff">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25z"/><line x1="2" y1="2" x2="22" y2="22" stroke="currentColor" stroke-width="2"/></svg>
                        </template>
                    </button>
                </template>

                {{-- Speaker toggle --}}
                <button @click="toggleSpeaker()"
                        class="w-12 h-12 rounded-full flex items-center justify-center transition-all"
                        :class="isSpeaker ? 'bg-white text-slate-900' : 'bg-slate-700 text-white hover:bg-slate-600'">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25h2.24z"/></svg>
                </button>

                {{-- Hang up --}}
                <button @click="hangUp()"
                        class="w-14 h-14 rounded-full bg-red-500 hover:bg-red-600 flex items-center justify-center shadow-lg transition-all hover:scale-110">
                    <svg class="w-7 h-7 text-white rotate-[135deg]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z"/></svg>
                </button>
            </div>
        </div>
    </template>

    {{-- Hidden audio for ringtone --}}
    <audio id="call-ringtone" loop preload="auto">
        <source src="data:audio/wav;base64,UklGRiQAAABXQVZFZm10IBAAAAABAAEARKwAAIhYAQACABAAZGF0YQAAAAA=" type="audio/wav">
    </audio>
</div>
